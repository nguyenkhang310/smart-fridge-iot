# Smart Fridge IoT - Environment Configuration Template
# Copy file này thành .env rồi điền giá trị thực

# IP tĩnh của ESP32-CAM (thay đổi ở đây thay vì sửa app.py)
ESP32_CAM_IP=192.168.x.x

# (Tuỳ chọn) Khoảng nghỉ tối thiểu giữa các frame khi stream từ ESP32 (giây, mặc định 0.5)
# ESP32_STREAM_MIN_INTERVAL=0.5

# (Tuỳ chọn) Cảnh báo cửa tủ mở quá lâu (giây)
# Hiện đang hard-code trong app.py, không bắt buộc cấu hình qua .env
# DOOR_OPEN_ALERT_SECONDS=30

# Flask secret key (bắt buộc khi deploy production)
# SECRET_KEY=your-secret-key-here
